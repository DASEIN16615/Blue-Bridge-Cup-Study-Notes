#include <stdio.h>
/*
统计每个数字中6的个数：
对于每个数字，计算其包含的6的个数（count6）
如果count6 > 6，这个数字可以单独成组，直接计入答案
如果count6 <= 6，将其加入c[count6]（c数组记录count6为i的数字数量）
分组策略（贪心算法）：
优先使用能用最少数字组成好数的组合
优先级从高到低：
5+2（5+2=7>6）：1个有5个6的数字 + 1个有2个6的数字
5+3（5+3=8>6）：1个有5个6的数字 + 1个有3个6的数字
5+4（5+4=9>6）：1个有5个6的数字 + 1个有4个6的数字
5+5（5+5=10>6）：2个有5个6的数字
4+3（4+3=7>6）：1个有4个6的数字 + 1个有3个6的数字
4+4（4+4=8>6）：2个有4个6的数字
4+1+2（4+1+2=7>6）：1个有4个6的数字 + 1个有1个6的数字 + 1个有2个6的数字
3+3+1（3+3+1=7>6）：2个有3个6的数字 + 1个有1个6的数字
3+2+2（3+2+2=7>6）：1个有3个6的数字 + 2个有2个6的数字
*/
int count6(int a)
{
    int count = 0;
    while (a > 0) {
        if (a % 10 == 6) {
            count++;
        }
        a /= 10;
    }
    return count;
}

int main()
{
    int n;
    scanf("%d", &n);

    int c[7] = {0}; // c[0]到c[6]，c[i]表示有i个6的数的数量

    for (int i = 0; i < n; i++)
    {
        int a;
        scanf("%d", &a);
        int num6 = count6(a);
        if (num6 > 6)
        {
            num6 = 6; // 只关注6个6及以下的情况
        }
        c[num6]++;
    }

    int ans = c[6]; // 所有6的个数不小于6的数单成一组

    // 处理c[5]：优先用c[1]，然后c[2]，然后c[3]，然后c[4]，最后两个c[5]配对
    if (c[1] < c[5]) {
        ans += c[1];
        c[5] -= c[1];
        c[1] = 0;
    }
    else
    {
        ans += c[5];
        c[1] -= c[5];
        c[5] = 0;
    }

    if (c[2] < c[5])
    {
        ans += c[2];
        c[5] -= c[2];
        c[2] = 0;
    } else
    {
        ans += c[5];
        c[2] -= c[5];
        c[5] = 0;
    }

    if (c[3] < c[5])
    {
        ans += c[3];
        c[5] -= c[3];
        c[3] = 0;
    }
    else
    {
        ans += c[5];
        c[3] -= c[5];
        c[5] = 0;
    }

    if (c[4] < c[5])
    {
        ans += c[4];
        c[5] -= c[4];
        c[4] = 0;
    }
    else
    {
        ans += c[5];
        c[4] -= c[5];
        c[5] = 0;
    }

    ans += c[5] / 2; // 两个c[5]配对
    c[5] %= 2;

    // 处理c[4]：优先用c[1]（每组需要2个c[1]），然后用c[2]，然后用c[3]
    if (c[1] >= 2)
    {
        int num = c[4] < c[1] / 2 ? c[4] : c[1] / 2;
        ans += num;
        c[4] -= num;
        c[1] -= num * 2;
    }

    if (c[2] < c[4])
    {
        ans += c[2];
        c[4] -= c[2];
        c[2] = 0;
    }
    else
    {
        ans += c[4];
        c[2] -= c[4];
        c[4] = 0;
    }

    if (c[3] < c[4])
    {
        ans += c[3];
        c[4] -= c[3];
        c[3] = 0;
    }
    else
    {
        ans += c[4];
        c[3] -= c[4];
        c[4] = 0;
    }

    // 处理c[3]、c[2]、c[1]：三者各一个组成一组
    int min_triple = c[3] < c[2] ? c[3] : c[2];
    min_triple = min_triple < c[1] ? min_triple : c[1];
    ans += min_triple;
    c[3] -= min_triple;
    c[2] -= min_triple;
    c[1] -= min_triple;

    // 处理剩余的c[3]和c[2]
    ans += (3 * c[3] + 2 * c[2]) / 6;

    printf("%d\n", ans);

    return 0;
}
