#include <stdio.h>

void adjust(int *a, int *b, int *c, int k) {
    for (int i = 0; i < k; i++) {
        int temp_a = *a;
        int temp_b = *b;
        int temp_c = *c;
        *a = (temp_b + temp_c) / 2;
        *b = (temp_a + temp_c) / 2;
        *c = (temp_a + temp_b) / 2;
        // 优化：当三值相等时提前终止
        if (*a == *b && *b == *c) {
            break;
        }
    }
}

int main() {
    int t;
    scanf("%d", &t);
    
    for (int i = 0; i < t; i++) {
        int A, B, C, K;
        scanf("%d %d %d %d", &A, &B, &C, &K);
        adjust(&A, &B, &C, K);
        printf("%d %d %d\n", A, B, C);
    }
    
    return 0;
}
